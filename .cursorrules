## Testing Strategy

### Unit Tests
```python
# tests/unit/llm/test_text_to_sql.py
import pytest
from src.llm.text_to_sql import TextToSqlEngine

@pytest.fixture
def engine():
    return TextToSqlEngine()

@pytest.mark.asyncio
async def test_simple_query(engine):
    sql = await engine.generate(
        "Show me all apartments in NYC"
    )
    assert "PROPERTY_TYPE" in sql
    assert "WHERE" in sql
    
@pytest.mark.asyncio
async def test_safety_validation(engine):
    with pytest.raises(InvalidQueryError):
        await engine.generate("DROP TABLE properties")
```

### Integration Tests
```python
@pytest.mark.asyncio
async def test_rag_pipeline_end_to_end(client):
    response = await client.post(
        "/api/rag/query",
        json={"query": "Show me my top 10 properties by NOI"}
    )
    assert response.status_code == 200
    assert "data" in response.json()
```

