```
src/
├── main.py              # 50-100 lines: app setup
├── api/                 # All endpoint handlers
│   ├── __init__.py
│   ├── auth.py
│   └── portfolio.py
├── services/            # Business logic, >100 lines per file OK
│   ├── text_to_sql.py
│   └── rag_pipeline.py
├── schemas/             # Pydantic models only
│   └── portfolio.py
└── utils/              # Helpers, validators
