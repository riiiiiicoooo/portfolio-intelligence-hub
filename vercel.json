{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "devCommand": "cd frontend && npm run dev",
  "installCommand": "npm install --legacy-peer-deps && cd frontend && npm install",
  "framework": "nextjs",
  "nodeVersion": "18.x",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://localhost:8000/api/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/materialized-views/refresh",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/embeddings/reindex",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cache/warm",
      "schedule": "*/30 * * * *"
    }
  ],
  "env": [
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_API_URL",
    "CLERK_SECRET_KEY",
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY"
  ]
}
